{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/chart-v1.schema.json",
  "title": "aio:chart@1",
  "description": "Candidate component. Structural shape for aio:chart@1 blocks. Cross-field invariants are enforced by the AIO validator at scripts/aio.mjs and are the source of truth: (1) for line/bar/area, every series.data array must have length equal to x.length; (2) every numeric value must be a finite real number (NaN, Infinity, -Infinity are rejected by the validator even though JSON Schema cannot express this); (3) pie/donut requires `slices` and ignores `x`/`series`; line/bar/area require `x` + `series` and ignore `slices`.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["line", "bar", "area", "pie", "donut"]
    },
    "title": { "type": "string", "maxLength": 100, "pattern": "^[^<>]*$" },
    "subtitle": { "type": "string", "maxLength": 160, "pattern": "^[^<>]*$" },
    "caption": { "type": "string", "maxLength": 180, "pattern": "^[^<>]*$" },
    "xLabel": { "type": "string", "maxLength": 40, "pattern": "^[^<>]*$" },
    "yLabel": { "type": "string", "maxLength": 40, "pattern": "^[^<>]*$" },
    "x": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 40, "pattern": "^[^<>]*$" }
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "maxLength": 80, "pattern": "^[^<>]*$" },
          "data": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "items": { "type": "number" }
          },
          "tone": { "type": "string", "enum": ["neutral", "good", "warn", "bad", "accent"] }
        },
        "required": ["name", "data"]
      }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "maxLength": 80, "pattern": "^[^<>]*$" },
          "value": { "type": "number", "minimum": 0 },
          "tone": { "type": "string", "enum": ["neutral", "good", "warn", "bad", "accent"] }
        },
        "required": ["label", "value"]
      }
    }
  },
  "required": ["type"]
}
